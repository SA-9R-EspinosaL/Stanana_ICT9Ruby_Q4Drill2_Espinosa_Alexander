<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Q4 Drill 2</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #1a2a3a 0%, #0f1a24 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            padding: 2rem 1rem;
        }

        .heat-card {
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            border: 1px solid rgba(255, 193, 7, 0.3);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: transform 0.2s ease;
        }

        .heat-card:hover {
            transform: translateY(-5px);
        }

        .heat-header {
            background: linear-gradient(98deg, #ff8c00, #ff6b00);
            border-radius: 2rem 2rem 0 0;
            padding: 1.5rem;
            text-align: center;
        }

        .heat-header h1 {
            font-weight: 800;
            font-size: 2rem;
            letter-spacing: -0.5px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .heat-header p {
            font-size: 0.9rem;
            opacity: 0.95;
        }

        .form-label-custom {
            font-family: 'Courier New', 'Fira Code', monospace;
            font-weight: bold;
            font-size: 1rem;
            background: rgba(255, 193, 7, 0.2);
            padding: 0.3rem 1rem;
            border-radius: 30px;
            display: inline-block;
            margin-bottom: 0.5rem;
            color: #ffde9e;
        }

        .form-control-custom {
            background: #fff;
            border: 2px solid #ff8c00;
            border-radius: 50px;
            padding: 0.7rem 1rem;
            font-size: 1rem;
            text-align: center;
            font-weight: 500;
            transition: all 0.2s;
        }

        .form-control-custom:focus {
            border-color: #ff5500;
            box-shadow: 0 0 0 0.2rem rgba(255, 140, 0, 0.25);
            outline: none;
        }

        .form-control-custom::placeholder {
            color: #aaa;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
        }

        .btn-check-heat {
            background: linear-gradient(95deg, #ff8c00, #ff5500);
            border: none;
            font-weight: 700;
            padding: 0.75rem 1.8rem;
            border-radius: 50px;
            width: 100%;
            font-size: 1.1rem;
            transition: all 0.2s;
            box-shadow: 0 8px 16px -6px rgba(255, 85, 0, 0.4);
        }

        .btn-check-heat:hover {
            background: linear-gradient(95deg, #e07a00, #dd4400);
            transform: scale(0.98);
            box-shadow: 0 4px 12px -3px rgba(255, 85, 0, 0.5);
        }

        details {
            background: rgba(255, 193, 7, 0.15);
            border-radius: 1rem;
            padding: 0.5rem 1rem;
            margin-bottom: 1rem;
            cursor: pointer;
        }

        summary {
            font-family: 'Courier New', monospace;
            font-weight: bold;
            color: #ffcc66;
            font-size: 0.95rem;
        }

        #noteText {
            font-size: 0.85rem;
            color: #ffecb3;
            font-style: italic;
            display: block;
            margin-top: 0.5rem;
        }

        .table-heat {
            background: rgba(0, 0, 0, 0.6);
            border-radius: 1rem;
            overflow: hidden;
            margin-top: 1rem;
        }

        .table-heat th {
            background: #ff8c00;
            color: #1a1a2e;
            font-weight: 700;
            border: none;
        }

        .table-heat td {
            color: #f0f0f0;
            border-color: #ff8c5040;
        }

        .info-footer a {
            color: #ffaa44;
            text-decoration: none;
            transition: 0.2s;
        }

        .info-footer a:hover {
            color: #ffcc66;
            text-decoration: underline;
        }

        .heat-img {
            filter: drop-shadow(0 10px 8px rgba(0,0,0,0.3));
            max-width: 100%;
            height: auto;
        }

        @media (max-width: 768px) {
            .heat-header h1 {
                font-size: 1.5rem;
            }
            body {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">
                <div class="heat-card">
                    <div class="heat-header text-white">
                        <h1> Heat Index Checker</h1>
                        <p class="mb-0">Calculate how hot it really feels — combining temperature & humidity</p>
                    </div>

                    <div class="p-4 p-md-5">
                        <div class="row align-items-center g-4">
                            <div class="col-md-7">
                                <details ontoggle="showInstructions()" open>
                                    <summary>📋 Note / Instructions</summary>
                                    <i id="noteText"></i>
                                </details>

                                <div class="mb-3">
                                    <label class="form-label-custom mb-1"> Degree in °C</label>
                                    <input type="number" id="temperatureInput" class="form-control form-control-custom" placeholder="e.g., 28" step="any" value="">
                                </div>

                                <div class="mb-4">
                                    <label class="form-label-custom mb-1">💧 Humidity in %</label>
                                    <input type="number" id="humidityInput" class="form-control form-control-custom" placeholder="e.g., 65" step="any" value="">
                                </div>

                                <button type="button" id="checkHeatBtn" class="btn btn-check-heat text-white fw-bold">
                                    🔥 Check Heat Index
                                </button>

                                <div id="outputMessage" class="mt-3 text-center" style="min-height: 55px;"></div>
                            </div>

                            <div class="col-md-5 text-center">
                                <img src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='45' fill='%23ff8c00'/%3E%3Ctext x='50' y='68' font-size='40' text-anchor='middle' fill='white' font-weight='bold'%3E🔥%3C/text%3E%3C/svg%3E" 
                                     alt="Heat icon" class="heat-img" style="width: 160px; height: 160px; border-radius: 30px; background: radial-gradient(circle, #ff8c0033, transparent); padding: 10px;">
                                <p class="text-warning small mt-2 fst-italic">Feels like temperature</p>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top border-warning">
                            <p class="text-light-emphasis small mb-2">
                                <strong> About Heat Index:</strong> The heat index (apparent temperature) measures what the human body feels 
                                when humidity is combined with actual air temperature. Higher humidity reduces sweat evaporation, 
                                making it feel hotter. Formula: <code class="text-warning">Heat Index = Temp + (0.33 × Humidity) - 4</code>.
                            </p>
                        </div>

                        <h5 class="text-warning mt-4 mb-2 fw-bold">📊 Heat Index Reference Chart</h5>
                        <div class="table-responsive">
                            <table class="table table-bordered table-heat">
                                <thead>
                                    <tr>
                                        <th>Temperature (°C)</th>
                                        <th>Humidity (%)</th>
                                        <th>Heat Index Range (°C)</th>
                                        <th>Status / Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>20 – 24</td><td>30 – 50</td><td>≤ 27</td><td>Comfortable / Cool</td></tr>
                                    <tr><td>25 – 27</td><td>40 – 60</td><td>28 – 32</td><td>Warm</td></tr>
                                    <tr><td>28 – 31</td><td>50 – 70</td><td>33 – 37</td><td>Hot</td></tr>
                                    <tr><td>32 – 35</td><td>60 – 80</td><td>38 – 41</td><td>Very Hot / Caution</td></tr>
                                    <tr><td>36+</td><td>70 – 100</td><td>≥ 42</td><td>Extreme Heat / Danger</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="info-footer d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3 pt-2 border-top border-secondary">
                            <div>
                                <span class="text-muted small">🔗 References & Tools:</span>
                                <a href="https://www.w3schools.com/js/" target="_blank" class="ms-2 me-2">w3schools JavaScript</a>
                                <a href="https://www.weather.gov/safety/heat-index" target="_blank" class="me-2">NOAA Heat Index</a>
                                <a href="https://getbootstrap.com/" target="_blank">Bootstrap Docs</a>
                            </div>
                            <div class="small text-muted">
                                🌍 National Oceanic and Atmospheric Administration (NOAA)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const tempInput = document.getElementById('temperatureInput');
        const humidInput = document.getElementById('humidityInput');
        const checkBtn = document.getElementById('checkHeatBtn');
        const outputMsgDiv = document.getElementById('outputMessage');

        function showInlineMessage(msg, isError = false) {
            if (isError) {
                outputMsgDiv.innerHTML = `<span class="badge bg-danger text-white p-2 rounded-pill">⚠️ ${msg}</span>`;
            } else {
                outputMsgDiv.innerHTML = `<span class="badge bg-success text-white p-2 rounded-pill">✅ ${msg}</span>`;
            }
            setTimeout(() => {
                if (outputMsgDiv.innerHTML.includes(msg)) {
                    outputMsgDiv.innerHTML = '';
                }
            }, 4000);
        }

        function computeHeatIndex() {
            let tempValue = parseFloat(tempInput.value);
            let humidityValue = parseFloat(humidInput.value);
            
            if (isNaN(tempValue) || isNaN(humidityValue)) {
                const errorMsg = "Please enter valid numeric values for temperature (°C) and humidity (%).";
                showInlineMessage(errorMsg, true);
                window.alert("⚠️ Input Error: " + errorMsg);
                return;
            }
            
            if (tempValue < -20) {
                showInlineMessage("Temperature seems too low. Enter a realistic value (e.g., -10 to 50 °C).", true);
                window.alert("Invalid temperature range. Please enter a valid temperature.");
                return;
            }
            if (humidityValue < 0 || humidityValue > 100) {
                showInlineMessage("Humidity must be between 0% and 100%.", true);
                window.alert("Humidity error: Please enter a percentage from 0 to 100.");
                return;
            }
            
            let heatIndex = tempValue + (0.33 * humidityValue) - 4;
            let heatIndexRounded = parseFloat(heatIndex.toFixed(1));
            
            let statusDescription = "";
            
            switch (true) {
                case (heatIndexRounded <= 27):
                    statusDescription = "Comfortable / Cool";
                    break;
                case (heatIndexRounded <= 32):
                    statusDescription = "Warm";
                    break;
                case (heatIndexRounded <= 37):
                    statusDescription = "Hot";
                    break;
                case (heatIndexRounded <= 41):
                    statusDescription = "Very Hot / Caution";
                    break;
                default:
                    statusDescription = "Extreme Heat / Danger";
                    break;
            }
            
            const resultMessage = `Heat Index: ${heatIndexRounded}°C\nStatus: ${statusDescription}`;
            window.alert(resultMessage);
            showInlineMessage(`Heat Index ${heatIndexRounded}°C → ${statusDescription}`, false);
        }
        
        function showInstructions() {
            const noteElement = document.getElementById("noteText");
            noteElement.innerHTML = "💡 Enter the air temperature (°C) and relative humidity (%). Then click 'Check Heat Index' to see the feels-like temperature and safety status based on NOAA classification.";
        }
        
        if (document.getElementById("noteText")) {
            showInstructions();
        }
        
        checkBtn.addEventListener('click', computeHeatIndex);
        
        const inputFields = [tempInput, humidInput];
        inputFields.forEach(field => {
            field.addEventListener('keypress', function(event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    computeHeatIndex();
                }
            });
        });
        
        outputMsgDiv.innerHTML = '<span class="text-muted small fst-italic">🌡️ Fill in temperature & humidity, then click Check.</span>';
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
